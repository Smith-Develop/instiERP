# =============================================================================
# Insti ERP — Variables de entorno
# =============================================================================
# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el .env con valores reales al repositorio.
# =============================================================================

# --- Base de datos (PostgreSQL / Supabase) ---

# URL del pooler de Supabase en modo transacción (pgbouncer=true requerido)
# Formato: postgresql://user.project_ref:password@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://user.project_ref:password@pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa para migraciones de Prisma (pooler en modo sesión, puerto 5432)
# Formato: postgresql://user.project_ref:password@aws-X-region.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://user.project_ref:password@pooler.supabase.com:5432/postgres"

# --- Autenticación (Better Auth) ---

# Secreto para firmar cookies de sesión y JWT. Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="genera-un-secreto-de-32-bytes-en-hex"

# URL base de la aplicación (sin barra al final)
BETTER_AUTH_URL="http://localhost:3000"

# --- Supabase Storage (documentos) ---

# URL pública de tu proyecto Supabase
# Formato: https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Key anónima de Supabase (pública, se expone al cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Key de servicio de Supabase (secreta, SOLO server-side, NUNCA expuesta al cliente)
# La encuentras en Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# --- Pagos (Stripe) ---

# Secreto para verificar webhooks de Stripe
# Lo obtienes en Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_tu_secreto_de_webhook"

# Las claves de Stripe se configuran por colegio en Settings → Pagos (no aquí)

# --- Emails (Resend) ---

# API key de Resend para envío de emails (recuperación de contraseña, notificaciones)
# Obtén la key en https://resend.com/api-keys
RESEND_API_KEY="re_tu_api_key"

# Email remitente (debe estar verificado en Resend)
RESEND_FROM_EMAIL="Insti ERP <noreply@tudominio.com>"

# --- Entorno ---

# Entorno de ejecución (development | production | test)
NODE_ENV="development"
